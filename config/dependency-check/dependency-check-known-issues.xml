<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- Apache Jena Fuseki server-side vulnerabilities: path traversal in admin dataset creation.
         LodView uses Jena only as a SPARQL *client* library, not as a Fuseki server.
         These CVEs do not apply. Upgrade to Jena 5.x deferred (breaking changes). -->
    <suppress>
        <notes><![CDATA[Fuseki server path traversal — not applicable: LodView is a SPARQL client, not a Fuseki server]]></notes>
        <cve>CVE-2025-50151</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[Fuseki server path traversal (dbName) — not applicable: LodView is a SPARQL client, not a Fuseki server]]></notes>
        <cve>CVE-2025-49656</cve>
    </suppress>

    <!-- Log4j Socket Appender TLS hostname verification bypass.
         LodView does not use Socket Appender for logging (only console/file). -->
    <suppress>
        <notes><![CDATA[Log4j Socket Appender TLS issue — not applicable: LodView does not use Socket Appender]]></notes>
        <cve>CVE-2025-68161</cve>
    </suppress>

    <!-- jQuery 1.12.4 bundled in static resources. Upgrade to 3.x deferred to future session
         (requires testing all JSP templates and JavaScript interactions). -->
    <suppress>
        <notes><![CDATA[jQuery 1.12.4 — upgrade deferred to future session]]></notes>
        <cve>CVE-2015-9251</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[jQuery 1.12.4 — upgrade deferred to future session]]></notes>
        <cve>CVE-2019-11358</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[jQuery 1.12.4 — upgrade deferred to future session]]></notes>
        <cve>CVE-2020-11022</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[jQuery 1.12.4 — upgrade deferred to future session]]></notes>
        <cve>CVE-2020-11023</cve>
    </suppress>

</suppressions>
